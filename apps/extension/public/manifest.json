{
  "manifest_version": 3,
  "name": "VC Tabs — Tab Manager",
  "version": "0.3.0",
  "description": "Save, organize, and restore your browser tabs into Spaces and Collections.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VC Tabs — Quick Access",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["http://localhost:3000/*", "https://*.vercel.app/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
