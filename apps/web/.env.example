# apps/web environment — COPY to .env.local (gitignored) and fill real values.
# Never commit real secrets. .env.local is ignored by git; this template is not.

# --- Database (Step 1) ---
# Your rotated MongoDB Atlas connection string. Use a least-privilege user
# (readWrite on the app DB), NOT an admin user. Put the DB name in the path.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vctabs?retryWrites=true&w=majority&appName=<app>"

# --- Auth (Step 1) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="<random-48-bytes-base64url>"
JWT_REFRESH_SECRET="<different-random-48-bytes-base64url>"

# Public base URL of this web app (used for CORS + verify/reset links).
# Dev: http://localhost:3000   Prod: https://<your-app>.vercel.app
APP_BASE_URL="http://localhost:3000"

# Comma-separated allowed origins for the extension to call the API (CORS).
# The chrome-extension://<id> origin (the unpacked id from chrome://extensions).
ALLOWED_ORIGINS="chrome-extension://<your-extension-id>"

# --- Email — Step 2 / fast-follow (leave blank for the lean first cut) ---
RESEND_API_KEY=""
EMAIL_FROM="VC Tabs <noreply@your-domain.com>"

# --- Rate limiting — Step 2 / fast-follow (leave blank for the lean first cut) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
